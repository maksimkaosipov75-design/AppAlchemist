# Maintainer: AppAlchemist Team <appalchemist@example.com>
pkgname=appalchemist
pkgver=1.5.0
pkgrel=1
pkgdesc="Convert .deb, .rpm and Linux archives into portable AppImage bundles"
arch=('x86_64')
url="https://github.com/maksimkaosipov75-design/AppAlchemist"
license=('MIT')
depends=('qt6-base' 'gtk4' 'libadwaita')
optdepends=('appimagetool: Required for building AppImages'
            'libnotify: For system notifications')
makedepends=('cmake' 'qt6-base' 'qt6-tools' 'pkgconf')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "${srcdir}/${pkgname}-${pkgver}"
}

build() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    mkdir -p build
    cd build
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    make
}

package() {
    cd "${srcdir}/${pkgname}-${pkgver}/build"
    make DESTDIR="${pkgdir}" install
    
    # Install desktop file
    install -Dm644 ../packaging/appalchemist.desktop \
        "${pkgdir}/usr/share/applications/appalchemist.desktop"
    
    # Install desktop file handlers
    install -Dm644 ../packaging/appalchemist-deb-handler.desktop \
        "${pkgdir}/usr/share/applications/appalchemist-deb-handler.desktop"
    
    install -Dm644 ../packaging/appalchemist-rpm-handler.desktop \
        "${pkgdir}/usr/share/applications/appalchemist-rpm-handler.desktop"
    
    # Install MIME type files
    install -Dm644 ../packaging/mime/deb-package.xml \
        "${pkgdir}/usr/share/mime/packages/deb-package.xml"
    
    install -Dm644 ../packaging/mime/rpm-package.xml \
        "${pkgdir}/usr/share/mime/packages/rpm-package.xml"
    
    # Install icon if available
    if [ -f ../assets/icons/appalchemist.png ]; then
        install -Dm644 ../assets/icons/appalchemist.png \
            "${pkgdir}/usr/share/pixmaps/appalchemist.png"
        
        for size in 16 32 48 64 128 256; do
            install -Dm644 ../assets/icons/appalchemist.png \
                "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/appalchemist.png"
        done
    fi
}

post_install() {
    # Update desktop database
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database -q
    fi
    
    # Update MIME database
    if command -v update-mime-database >/dev/null 2>&1; then
        update-mime-database /usr/share/mime
    fi
}

post_upgrade() {
    post_install
}

post_remove() {
    # Update desktop database
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database -q
    fi
    
    # Update MIME database
    if command -v update-mime-database >/dev/null 2>&1; then
        update-mime-database /usr/share/mime
    fi
}
